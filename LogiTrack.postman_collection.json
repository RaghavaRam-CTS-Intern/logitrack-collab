{
  "info": {
    "name": "LogiTrack Backend (port 8085)",
    "description": "Full API collection for the LogiTrack Supply-Chain backend.\n\nHOW TO USE:\n1. Make sure the app is running on http://localhost:8085 and MySQL is up.\n2. Open the 'Auth > Login (SHIPPER)' request and hit Send. The test script auto-saves the JWT into the collection variable {{token}}.\n3. Every other request already sends 'Authorization: Bearer {{token}}', so they just work.\n4. Log in as a different seeded user (coordinator/warehouseops/driver/analyst@logitrack.com, all password123) any time to switch roles.\n\nSeeded login emails (password = password123):\n  shipper@logitrack.com, coordinator@logitrack.com, warehouseops@logitrack.com, driver@logitrack.com, analyst@logitrack.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8085" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "shipmentId", "value": "1" },
    { "key": "freightOrderId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (create new user)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@logitrack.com\",\n  \"password\": \"password123\",\n  \"role\": \"SHIPPER\",\n  \"phone\": \"9000000001\",\n  \"hubId\": 1\n}" }
          }
        },
        {
          "name": "Login (SHIPPER)  <-- RUN THIS FIRST",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('userId', json.userId);",
                  "  console.log('Token saved for', json.name, '(' + json.role + ')');",
                  "}",
                  "pm.test('login ok', function(){ pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"shipper@logitrack.com\",\n  \"password\": \"password123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "Create user", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": {"raw":"{{baseUrl}}/api/users","host":["{{baseUrl}}"],"path":["api","users"]}, "body": {"mode":"raw","raw":"{\n  \"name\": \"Jane Analyst\",\n  \"email\": \"jane.analyst@logitrack.com\",\n  \"password\": \"password123\",\n  \"role\": \"ANALYST\",\n  \"phone\": \"9000000009\",\n  \"hubId\": 2\n}"} } },
        { "name": "Get all users", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/users","host":["{{baseUrl}}"],"path":["api","users"]} } },
        { "name": "Get user by id", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/users/1","host":["{{baseUrl}}"],"path":["api","users","1"]} } },
        { "name": "Update user status (?status=INACTIVE)", "request": { "method": "PATCH", "url": {"raw":"{{baseUrl}}/api/users/6?status=INACTIVE","host":["{{baseUrl}}"],"path":["api","users","6"],"query":[{"key":"status","value":"INACTIVE"}]} } },
        { "name": "Delete user", "request": { "method": "DELETE", "url": {"raw":"{{baseUrl}}/api/users/6","host":["{{baseUrl}}"],"path":["api","users","6"]} } }
      ]
    },
    {
      "name": "Carriers",
      "item": [
        { "name": "Create carrier", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": {"raw":"{{baseUrl}}/api/carriers","host":["{{baseUrl}}"],"path":["api","carriers"]}, "body": {"mode":"raw","raw":"{\n  \"name\": \"RailFreight Co\",\n  \"mode\": \"RAIL\",\n  \"serviceLevel\": \"STANDARD\",\n  \"contactDetails\": \"contact@railfreight.com\"\n}"} } },
        { "name": "Get all carriers (optional ?mode=ROAD)", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/carriers","host":["{{baseUrl}}"],"path":["api","carriers"],"query":[{"key":"mode","value":"ROAD","disabled":true}]} } },
        { "name": "Get carrier by id", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/carriers/1","host":["{{baseUrl}}"],"path":["api","carriers","1"]} } },
        { "name": "Update carrier status (?status=SUSPENDED)", "request": { "method": "PATCH", "url": {"raw":"{{baseUrl}}/api/carriers/1?status=SUSPENDED","host":["{{baseUrl}}"],"path":["api","carriers","1"],"query":[{"key":"status","value":"SUSPENDED"}]} } },
        { "name": "Delete carrier", "request": { "method": "DELETE", "url": {"raw":"{{baseUrl}}/api/carriers/4","host":["{{baseUrl}}"],"path":["api","carriers","4"]} } }
