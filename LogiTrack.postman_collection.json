        { "name": "Get route by id", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/routes/1","host":["{{baseUrl}}"],"path":["api","routes","1"]} } },
        { "name": "Update route status (?status=INACTIVE)", "request": { "method": "PATCH", "url": {"raw":"{{baseUrl}}/api/routes/1?status=INACTIVE","host":["{{baseUrl}}"],"path":["api","routes","1"],"query":[{"key":"status","value":"INACTIVE"}]} } },
