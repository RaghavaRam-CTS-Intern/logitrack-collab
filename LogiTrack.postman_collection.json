        { "name": "Get rate cards by carrier (?carrierId=1)", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/rate-cards?carrierId=1","host":["{{baseUrl}}"],"path":["api","rate-cards"],"query":[{"key":"carrierId","value":"1"}]} } },
        { "name": "Get rate cards by route (?routeId=1)", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/rate-cards?routeId=1","host":["{{baseUrl}}"],"path":["api","rate-cards"],"query":[{"key":"routeId","value":"1"}]} } },
        { "name": "Get rate card by id", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/rate-cards/1","host":["{{baseUrl}}"],"path":["api","rate-cards","1"]} } },
        { "name": "Update rate card status (?status=INACTIVE)", "request": { "method": "PATCH", "url": {"raw":"{{baseUrl}}/api/rate-cards/1?status=INACTIVE","host":["{{baseUrl}}"],"path":["api","rate-cards","1"],"query":[{"key":"status","value":"INACTIVE"}]} } }
      ]
