      "name": "Suppliers",
      "item": [
        { "name": "Create supplier", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": {"raw":"{{baseUrl}}/api/suppliers","host":["{{baseUrl}}"],"path":["api","suppliers"]}, "body": {"mode":"raw","raw":"{\n  \"name\": \"GreenPack Materials\",\n  \"category\": \"Packaging\",\n  \"contactDetails\": \"greenpack@suppliers.com\",\n  \"leadTimeDays\": 5\n}"} } },
        { "name": "Get all suppliers", "request": { "method": "GET", "url": {"raw":"{{baseUrl}}/api/suppliers","host":["{{baseUrl}}"],"path":["api","suppliers"]} } },
